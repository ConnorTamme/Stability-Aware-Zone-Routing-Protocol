#!/bin/bash
cd "$(dirname "$0")"

EXPERIMENTS="FanetRecon FanetSar FanetStress"

for exp in $EXPERIMENTS; do
    echo "=========================================================="
    echo " Starting experiment set: $exp"
    echo "=========================================================="
    
    cd "$exp" || { echo "Failed to enter $exp"; continue; }
    
    # We dynamically find all leaf configurations in the omnetpp.ini
    # by catching lines like "[Config Recon_NodeSweep_StabilityZrp]" 
    # and excluding base configs without an underscore.
    CONFIGS=$(grep -hE '^\[Config ' omnetpp.ini | awk '{print $2}' | tr -d ']' | grep '_')
    
    for config in $CONFIGS; do
        echo "----------------------------------------------------------"
        echo " Running Scenario: $exp -> $config"
        echo "----------------------------------------------------------"
        
        # -u Cmdenv forces terminal/headless execution 
        # opp_runall automatically queries the number of sweeps/repeats and runs them in parallel 
        # across all available CPU cores (-j $(nproc)).
        opp_runall -j $(nproc) ./run -u Cmdenv -c "$config" "$@"
        
        if [ $? -ne 0 ]; then
             echo "==== Error encountered during $config in $exp! ===="
        fi
    done
    
    echo "=========================================================="
    echo " Generating Results & Exports for $exp..."
    echo "=========================================================="
    
    # Auto-generate a basic OMNeT++ Analysis File (.anf)
    cat <<EOF > results.anf
<?xml version="1.0" encoding="UTF-8"?>
<analysis version="2">
    <inputs>
        <input pattern="/SA-ZRP/simulations/$exp/results/*.vec"/>
        <input pattern="/SA-ZRP/simulations/$exp/results/*.sca"/>
    </inputs>
    <charts/>
</analysis>
EOF
    
    # Export all scalar and vector results to standard CSVs for Python/pandas analysis
    if command -v scavetool &> /dev/null; then
        echo "Exporting results to CSV using scavetool..."
        scavetool x results/*.sca -o results_scalars.csv 2>/dev/null
        scavetool x results/*.vec -o results_vectors.csv 2>/dev/null
    else
        echo "Warning: scavetool not found in PATH! CSV exports skipped."
    fi
    
    cd ..
done

echo "=========================================================="
echo " All main configurations have been successfully run!"
echo "=========================================================="

echo "All experiments finished!"